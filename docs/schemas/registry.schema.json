{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/weslleycapelari/github-patterns/main/docs/schemas/registry.schema.json",
  "title": "Marketplace Registry Schema",
  "description": "Schema for validating github-patterns registry.json with map-based asset catalogs.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "lastUpdated",
    "maintainer",
    "endpoint_base",
    "core",
    "stacks",
    "assets"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri-reference",
      "description": "Optional local or remote schema reference."
    },
    "version": {
      "$ref": "#/$defs/semanticVersion",
      "description": "Registry semantic version."
    },
    "lastUpdated": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp for latest registry update."
    },
    "maintainer": {
      "$ref": "#/$defs/nonEmptyString",
      "description": "Registry maintainer identifier."
    },
    "endpoint_base": {
      "type": "string",
      "format": "uri",
      "pattern": "/$",
      "description": "Base URL used to resolve relative source paths. Must end with '/'."
    },
    "metadata": {
      "$ref": "#/$defs/metadata",
      "description": "Registry metadata and documentation locale settings."
    },
    "governance": {
      "$ref": "#/$defs/governance",
      "description": "Global governance defaults such as blueprint and phase order."
    },
    "core": {
      "type": "object",
      "minProperties": 1,
      "description": "Governance blueprints with phase definitions.",
      "additionalProperties": {
        "$ref": "#/$defs/coreBlueprint"
      }
    },
    "stacks": {
      "type": "object",
      "minProperties": 1,
      "description": "Technology stack recommendations mapped by stack ID.",
      "additionalProperties": {
        "$ref": "#/$defs/stackDefinition"
      }
    },
    "assets": {
      "$ref": "#/$defs/assetsCatalog",
      "description": "Complete map-based catalog of installable assets."
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "semanticVersion": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
    },
    "assetId": {
      "type": "string",
      "pattern": "^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?$",
      "minLength": 1,
      "maxLength": 128
    },
    "phaseCode": {
      "type": "string",
      "enum": [
        "A",
        "B",
        "C",
        "D",
        "E"
      ]
    },
    "pathString": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[^\\\\]+$",
      "description": "Repository-relative path using forward slashes."
    },
    "uniqueStringArray": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/nonEmptyString"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "assetIdArray": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/assetId"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "tagArray": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9-]+$",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "description",
        "repository_url",
        "default_branch",
        "documentation"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "description": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "repository_url": {
          "type": "string",
          "format": "uri"
        },
        "default_branch": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "documentation": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "default_locale",
            "supported_locales"
          ],
          "properties": {
            "default_locale": {
              "$ref": "#/$defs/nonEmptyString"
            },
            "supported_locales": {
              "$ref": "#/$defs/uniqueStringArray"
            }
          }
        }
      }
    },
    "governance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "default_blueprint",
        "phase_order"
      ],
      "properties": {
        "default_blueprint": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "phase_order": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/phaseCode"
          },
          "uniqueItems": true,
          "minItems": 5,
          "maxItems": 5
        }
      }
    },
    "phaseDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "objective",
        "assets"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "objective": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "assets": {
          "$ref": "#/$defs/assetIdArray"
        },
        "prerequisites": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/phaseCode"
          },
          "uniqueItems": true,
          "minItems": 1
        }
      }
    },
    "coreBlueprint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "display_name",
        "description",
        "phases"
      ],
      "properties": {
        "display_name": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "description": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "phases": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "A",
            "B",
            "C",
            "D",
            "E"
          ],
          "properties": {
            "A": {
              "$ref": "#/$defs/phaseDefinition"
            },
            "B": {
              "$ref": "#/$defs/phaseDefinition"
            },
            "C": {
              "$ref": "#/$defs/phaseDefinition"
            },
            "D": {
              "$ref": "#/$defs/phaseDefinition"
            },
            "E": {
              "$ref": "#/$defs/phaseDefinition"
            }
          }
        }
      }
    },
    "stackDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "display_name",
        "description",
        "primary_languages",
        "recommended_phase",
        "recommended_assets"
      ],
      "properties": {
        "display_name": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "description": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "primary_languages": {
          "$ref": "#/$defs/uniqueStringArray"
        },
        "recommended_phase": {
          "$ref": "#/$defs/phaseCode"
        },
        "recommended_assets": {
          "$ref": "#/$defs/assetIdArray"
        }
      }
    },
    "agentAsset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "path",
        "description",
        "version",
        "tags"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/assetId"
        },
        "path": {
          "$ref": "#/$defs/pathString"
        },
        "description": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "version": {
          "$ref": "#/$defs/semanticVersion"
        },
        "tags": {
          "$ref": "#/$defs/tagArray"
        }
      }
    },
    "instructionAsset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "path",
        "target",
        "description",
        "version"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/assetId"
        },
        "path": {
          "$ref": "#/$defs/pathString"
        },
        "target": {
          "$ref": "#/$defs/pathString"
        },
        "description": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "version": {
          "$ref": "#/$defs/semanticVersion"
        }
      }
    },
    "workflowAsset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "path",
        "target",
        "description",
        "version"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/assetId"
        },
        "path": {
          "$ref": "#/$defs/pathString"
        },
        "target": {
          "$ref": "#/$defs/pathString"
        },
        "description": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "version": {
          "$ref": "#/$defs/semanticVersion"
        }
      }
    },
    "issueStrategyAsset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "path",
        "display_name",
        "description",
        "config",
        "templates",
        "version"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/assetId"
        },
        "path": {
          "$ref": "#/$defs/pathString"
        },
        "display_name": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "description": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "config": {
          "$ref": "#/$defs/pathString"
        },
        "templates": {
          "$ref": "#/$defs/uniqueStringArray"
        },
        "version": {
          "$ref": "#/$defs/semanticVersion"
        }
      }
    },
    "standardAsset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "path",
        "target",
        "title",
        "description",
        "version"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/assetId"
        },
        "path": {
          "$ref": "#/$defs/pathString"
        },
        "target": {
          "$ref": "#/$defs/pathString"
        },
        "title": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "description": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "version": {
          "$ref": "#/$defs/semanticVersion"
        }
      }
    },
    "intelligenceAsset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "path",
        "target",
        "description",
        "version"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/assetId"
        },
        "path": {
          "$ref": "#/$defs/pathString"
        },
        "target": {
          "$ref": "#/$defs/pathString"
        },
        "description": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "version": {
          "$ref": "#/$defs/semanticVersion"
        }
      }
    },
    "mcpServerAsset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "path",
        "description",
        "version",
        "type"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/assetId"
        },
        "path": {
          "$ref": "#/$defs/pathString"
        },
        "description": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "version": {
          "$ref": "#/$defs/semanticVersion"
        },
        "type": {
          "type": "string",
          "enum": [
            "config",
            "tool"
          ]
        }
      }
    },
    "assetsCatalog": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "agents",
        "instructions",
        "workflows",
        "issue_strategies",
        "standards",
        "intelligence",
        "mcp_servers"
      ],
      "properties": {
        "agents": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "$ref": "#/$defs/agentAsset"
          }
        },
        "instructions": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "$ref": "#/$defs/instructionAsset"
          }
        },
        "workflows": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "$ref": "#/$defs/workflowAsset"
          }
        },
        "issue_strategies": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "$ref": "#/$defs/issueStrategyAsset"
          }
        },
        "standards": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "$ref": "#/$defs/standardAsset"
          }
        },
        "intelligence": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "$ref": "#/$defs/intelligenceAsset"
          }
        },
        "mcp_servers": {
          "type": "object",
          "minProperties": 0,
          "additionalProperties": {
            "$ref": "#/$defs/mcpServerAsset"
          }
        }
      }
    }
  }
}